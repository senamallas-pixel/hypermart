# ===================================================================
# HyperMart Frontend Environment Variables
# ===================================================================
# Copy this file to `.env` and fill in your actual values
# These are processed by Vite (must start with VITE_)
# ===================================================================

# ── API Configuration ───────────────────────────────────────────────

# Backend API Base URL
# Local development: http://localhost:8000
# Production (Render): https://hypermart-ukg0.onrender.com
# For Vercel deployment, set this in Vercel dashboard Environment Variables
VITE_API_URL=http://localhost:8000

# ── Feature Flags ───────────────────────────────────────────────────

# Enable AI features (chat, suggestions, forecasts)
VITE_ENABLE_AI=true

# Enable UPI payments
VITE_ENABLE_UPI=true

# Enable offline mode
VITE_ENABLE_OFFLINE=false

# ── Payment Configuration (Public Keys Only) ────────────────────────

# Razorpay Key ID (public key, safe to expose)
# Get from: https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=rzp_test_ScGuDdSnrFFMy2

# ── App Configuration ───────────────────────────────────────────────

# App Name
VITE_APP_NAME=HyperMart

# App Version
VITE_APP_VERSION=1.0.0

# Environment Mode
# Options: development, staging, production
VITE_ENVIRONMENT=development

# ── Analytics & Monitoring ──────────────────────────────────────────

# Google Analytics ID (optional)
# VITE_GA_ID=G-XXXXXXXXXX

# Sentry DSN (optional)
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ===================================================================
# DEPLOYMENT NOTES
# ===================================================================
# 
# Vercel Deployment:
# 1. Go to: Vercel Dashboard → Your Project → Settings → Environment Variables
# 2. Add: VITE_API_URL = https://hypermart-ukg0.onrender.com
# 3. Environment: Production, Preview, Development
# 4. Save and redeploy
#
# Local Development:
# 1. Copy this file: cp .env.example .env
# 2. Keep VITE_API_URL=http://localhost:8000
# 3. Start dev server: npm run dev
# 4. Backend must be running on port 8000
#
# Production URLs:
# - Frontend: https://frontend-phi-five-15.vercel.app
# - Backend:  https://hypermart-ukg0.onrender.com
# ===================================================================
