# ===================================================================
# HyperMart Backend Environment Variables
# ===================================================================
# Copy this file to `.env` and fill in your actual values
# NEVER commit `.env` file with real credentials to git!
# ===================================================================

# ── Database Configuration ──────────────────────────────────────────

# PostgreSQL Connection (Production - Render)
# Format: postgresql://username:password@hostname:port/database
# Get the External Database URL from your Render PostgreSQL dashboard
DATABASE_URL=postgresql://hypermart_user:YOUR_PASSWORD_HERE@dpg-d7dbcdt7vec73819d70-a:5432/hypermart

# PostgreSQL Connection Details (for reference)
# Hostname: dpg-d7dbcdt7vec73819d70-a
# Port: 5432
# Database: hypermart
# Username: hypermart_user
# Password: (see Render PostgreSQL dashboard)

# SQLite Connection (Local Development - Alternative)
# Uncomment to use SQLite instead of PostgreSQL for local dev
# DATABASE_URL=sqlite:///./hypermart.db

# Database Debugging
# Set to "true" to see SQL queries in logs
SQL_ECHO=false

# ── Security & Authentication ───────────────────────────────────────

# JWT Secret Key (CRITICAL - MUST BE UNIQUE)
# Generate with: openssl rand -hex 32
# For production, this is set in Render dashboard
JWT_SECRET=your-secret-key-here-replace-with-generated-value

# JWT Token Expiration (in days)
JWT_EXPIRY_DAYS=30

# ── AI Features (Google Gemini) ─────────────────────────────────────

# Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
# Required for: AI chat, product suggestions, sales forecasts
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API Key (Legacy - if using OpenAI instead)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Payment Gateway (Razorpay) ──────────────────────────────────────

# Razorpay API Credentials
# Get from: https://dashboard.razorpay.com/app/keys
# Test mode keys start with: rzp_test_
# Live mode keys start with: rzp_live_
RAZORPAY_KEY_ID=rzp_test_ScGuDdSnrFFMy2
RAZORPAY_KEY_SECRET=your-razorpay-secret-here

# ── File Upload Configuration ───────────────────────────────────────

# Maximum file upload size in MB
MAX_UPLOAD_MB=10

# Cloudinary configuration (required for image uploads)
# Create credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional folder prefix in your Cloudinary media library
CLOUDINARY_FOLDER=hypermart

# ── Server Configuration ────────────────────────────────────────────

# Server Host (use 0.0.0.0 for Docker/Render)
HOST=0.0.0.0

# Server Port (use $PORT on Render for auto-assignment)
PORT=8000

# Environment Mode
# Options: development, production
ENVIRONMENT=development

# CORS Origins (comma-separated)
# For local dev: http://localhost:5173
# For production: https://frontend-phi-five-15.vercel.app
CORS_ORIGINS=http://localhost:5173,https://frontend-phi-five-15.vercel.app

# ── Render-Specific (Managed by Render) ─────────────────────────────

# These are automatically set by Render, no need to configure:
# - DATABASE_URL (from PostgreSQL database connection)
# - PORT (auto-assigned by Render)
# - PYTHON_VERSION (set in render.yaml)

# ===================================================================
# IMPORTANT SECURITY NOTES
# ===================================================================
# 1. NEVER commit .env with real values to git
# 2. Generate unique JWT_SECRET for each environment
# 3. Use test Razorpay keys for development
# 4. Use strong passwords for PostgreSQL
# 5. Rotate secrets regularly
# 6. Enable GitHub secret scanning
# ===================================================================

# ===================================================================
# LOCAL DEVELOPMENT SETUP
# ===================================================================
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Generate JWT secret:
#    openssl rand -hex 32
#
# 3. For SQLite (quick start):
#    DATABASE_URL=sqlite:///./hypermart.db
#
# 4. For PostgreSQL (production-like):
#    Install PostgreSQL locally
#    Create database: createdb hypermart
#    Set DATABASE_URL with your local credentials
#
# 5. Start backend:
#    uvicorn main:app --reload
#
# 6. Seed database:
#    python seed.py --reset
# ===================================================================
