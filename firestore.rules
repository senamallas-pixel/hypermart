rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, role (admin, owner, customer), displayName, photoURL, phone, createdAt
    //
    // Collection: shops
    // Fields: id, ownerId, name, address, category, status (pending, approved, suspended), logo, timings, location, createdAt
    //
    // Collection: products
    // Fields: id, shopId, name, price, mrp, unit, category, stock, image, status (active, out_of_stock), createdAt
    //
    // Collection: orders
    // Fields: id, shopId, customerId, items (array), total, status (pending, accepted, ready, out_for_delivery, delivered, rejected), paymentStatus, deliveryAddress, createdAt
    //
    // Collection: categories
    // Fields: id, name, image
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "srujan77991@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isShopOwner(shopId) {
      return isAuthenticated() && get(/databases/$(database)/documents/shops/$(shopId)).data.ownerId == request.auth.uid;
    }

    function isOrderCustomer(orderId) {
      return isAuthenticated() && get(/databases/$(database)/documents/orders/$(orderId)).data.customerId == request.auth.uid;
    }

    function isOrderShopOwner(orderId) {
      let order = get(/databases/$(database)/documents/orders/$(orderId)).data;
      return isAuthenticated() && get(/databases/$(database)/documents/shops/$(order.shopId)).data.ownerId == request.auth.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'owner', 'customer'];
    }

    function isValidShop(data) {
      return data.keys().hasAll(['id', 'ownerId', 'name', 'status']) &&
             data.id is string &&
             data.ownerId is string &&
             data.name is string &&
             data.status in ['pending', 'approved', 'suspended'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'shopId', 'name', 'price', 'status']) &&
             data.id is string &&
             data.shopId is string &&
             data.name is string &&
             data.price is number &&
             data.status in ['active', 'out_of_stock'];
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'shopId', 'customerId', 'items', 'total', 'status']) &&
             data.id is string &&
             data.shopId is string &&
             data.customerId is string &&
             data.items is list &&
             data.total is number &&
             data.status in ['pending', 'accepted', 'ready', 'out_for_delivery', 'delivered', 'rejected'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role != 'admin' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /shops/{shopId} {
      allow read: if resource.data.status == 'approved' || isOwner(resource.data.ownerId) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid && isValidShop(request.resource.data) && (request.resource.data.status == 'pending' || isAdmin());
      allow update: if isAuthenticated() && (isOwner(resource.data.ownerId) || isAdmin()) && isValidShop(request.resource.data) && (request.resource.data.status == resource.data.status || isAdmin());
    }

    match /products/{productId} {
      allow read: if resource.data.status == 'active' || isShopOwner(resource.data.shopId) || isAdmin();
      allow create: if isAuthenticated() && isShopOwner(request.resource.data.shopId) && isValidProduct(request.resource.data);
      allow update: if isAuthenticated() && (isShopOwner(resource.data.shopId) || isAdmin()) && isValidProduct(request.resource.data);
      allow delete: if isAuthenticated() && (isShopOwner(resource.data.shopId) || isAdmin());
    }

    match /orders/{orderId} {
      allow read: if isOrderCustomer(orderId) || isOrderShopOwner(orderId) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.customerId == request.auth.uid && isValidOrder(request.resource.data);
      allow update: if isAuthenticated() && (isOrderCustomer(orderId) || isOrderShopOwner(orderId) || isAdmin()) && isValidOrder(request.resource.data);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
