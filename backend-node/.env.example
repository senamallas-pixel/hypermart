# ===================================================================
# HyperShopIndia Backend (Node.js) Environment Variables
# ===================================================================
# Copy this file to `.env` and fill in your actual values
# NEVER commit `.env` file with real credentials to git!
# ===================================================================

# ── Database Configuration ──────────────────────────────────────────

# PostgreSQL Connection (Production - Render)
# Format: postgresql://username:password@hostname:port/database
# Get the External Database URL from your Render PostgreSQL dashboard
DATABASE_URL=postgresql://hypermart_user:YOUR_PASSWORD_HERE@dpg-d7dbcdt7vec73819d70-a:5432/hypermart

# PostgreSQL Connection Details (for reference)
# Hostname: dpg-d7dbcdt7vec73819d70-a
# Port: 5432
# Database: hypermart
# Username: hypermart_user
# Password: (see Render PostgreSQL dashboard)

# SQLite Connection (Local Development - Alternative)
# This Node.js backend uses sql.js (WASM SQLite)
# No configuration needed for SQLite - uses hypermart.db file

# ── Security & Authentication ───────────────────────────────────────

# JWT Secret Key (CRITICAL - MUST BE UNIQUE)
# Generate with: openssl rand -hex 32
# For production, this is set in Render dashboard
JWT_SECRET=your-secret-key-here-replace-with-generated-value

# JWT Token Expiration (in days)
JWT_EXPIRY_DAYS=30

# ── AI Features ─────────────────────────────────────────────────────

# OpenRouter API Key (PREFERRED provider when set)
# Get from: https://openrouter.ai/keys
# When present, AI calls use https://openrouter.ai/api/v1/chat/completions
# with model default `openai/gpt-4o-mini` and HTTP-Referer + X-Title headers.
OPENROUTER_API_KEY=

# Optional: override the AI model id (OpenRouter needs a vendor prefix)
# OPENAI_MODEL=openai/gpt-4o-mini

# Optional: HTTP-Referer sent to OpenRouter for attribution
# APP_URL=https://hypershopindia.com

# Google Gemini API Key (FALLBACK — used only when OPENROUTER_API_KEY is unset)
# Get from: https://makersuite.google.com/app/apikey
# Required for: AI chat, product suggestions, sales forecasts
GEMINI_API_KEY=your-gemini-api-key-here

# ── Email / SMTP (transactional notifications) ──────────────────────

# If unset, email is a graceful no-op (in-app notifications still work).
# SMTP_PORT: 465 = SSL, 587 = STARTTLS
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=HyperShopIndia

# ── Payment Gateway (Razorpay) ──────────────────────────────────────

# Razorpay API Credentials
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_ScGuDdSnrFFMy2
RAZORPAY_KEY_SECRET=your-razorpay-secret-here

# ── File Upload Configuration ───────────────────────────────────────

# Maximum file upload size in MB
MAX_UPLOAD_MB=10

# ── Server Configuration ────────────────────────────────────────────

# Server Port
PORT=8000

# Environment Mode
NODE_ENV=development

# ===================================================================
# LOCAL DEVELOPMENT SETUP (Node.js Backend)
# ===================================================================
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Generate JWT secret:
#    openssl rand -hex 32
#
# 3. Install dependencies:
#    npm install
#
# 4. Start server:
#    npm run dev
#
# 5. Seed database:
#    npm run seed:reset
# ===================================================================
