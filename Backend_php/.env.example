# HyperShopIndia PHP API — environment template. Copy to .env and fill in.

# ── MySQL (Hostinger → Databases → MySQL Databases) ──
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hypermart
DB_USER=hypermart_user
DB_PASS=change-me

# ── Auth ──
JWT_SECRET=change-this-to-a-long-random-string

# ── Seed protection (required to run seed.php over HTTP) ──
SEED_TOKEN=

# ── Razorpay (optional — payments) ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── AI (optional — chat & insights). Use OpenRouter OR OpenAI. ──
OPENROUTER_API_KEY=
# AI_BASE_URL=   # optional override, e.g. https://openrouter.ai/api/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Image uploads (stored on the Hostinger filesystem) ──
# Files are saved under the API root's uploads/ folder and served at /api/uploads/.
# Override only if you want a custom location/URL:
# UPLOAD_DIR=         # absolute path; default: <api-root>/uploads
# UPLOAD_URL_PREFIX=  # public URL path prefix; default: /uploads
MAX_UPLOAD_MB=5

# ── Email / notifications (Hostinger SMTP) ──
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@hypershopindia.com
SMTP_PASS=
SMTP_FROM=noreply@hypershopindia.com
SMTP_FROM_NAME=HyperShopIndia
# SMTP_SECURE=ssl   # ssl for 465, tls for 587 (auto by port if unset)
