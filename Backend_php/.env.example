# HyperMart PHP API — environment template. Copy to .env and fill in.

# ── MySQL (Hostinger → Databases → MySQL Databases) ──
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hypermart
DB_USER=hypermart_user
DB_PASS=change-me

# ── Auth ──
JWT_SECRET=change-this-to-a-long-random-string

# ── Seed protection (required to run seed.php over HTTP) ──
SEED_TOKEN=

# ── Razorpay (optional — payments) ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── AI (optional — chat & insights). Use OpenRouter OR OpenAI. ──
OPENROUTER_API_KEY=
# AI_BASE_URL=   # optional override, e.g. https://openrouter.ai/api/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Cloudinary (optional — image uploads) ──
# Either CLOUDINARY_URL, or the three separate vars below.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=hypermart
MAX_UPLOAD_MB=5
