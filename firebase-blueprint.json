{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "owner", "customer"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Shop": {
      "title": "Shop",
      "description": "Local shop details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "suspended"] },
        "logo": { "type": "string", "format": "uri" },
        "timings": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "name", "status"]
    },
    "Product": {
      "title": "Product",
      "description": "Product in a shop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "mrp": { "type": "number" },
        "unit": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "image": { "type": "string", "format": "uri" },
        "status": { "type": "string", "enum": ["active", "out_of_stock"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "shopId", "name", "price", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string" },
        "customerId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "ready", "out_for_delivery", "delivered", "rejected"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid"] },
        "deliveryAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "shopId", "customerId", "items", "total", "status"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "image": { "type": "string", "format": "uri" }
      },
      "required": ["id", "name"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/shops/{shopId}": { "schema": "Shop", "description": "Shop listings" },
    "/products/{productId}": { "schema": "Product", "description": "Product catalog" },
    "/orders/{orderId}": { "schema": "Order", "description": "Customer orders" },
    "/categories/{categoryId}": { "schema": "Category", "description": "Marketplace categories" }
  }
}
